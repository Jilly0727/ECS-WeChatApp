.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f6fa;
}

/* ── 用户信息头部 ── */

.profile-header {
  background: linear-gradient(135deg, #007aff, #00b4d8);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 32rpx;
}

.profile-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.4);
  background: #e0e0e0;
  margin-bottom: 20rpx;
}

.profile-nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.level-tag {
  background: rgba(255, 255, 255, 0.25);
  border-radius: 20rpx;
  padding: 6rpx 24rpx;
  margin-bottom: 12rpx;
}

.level-tag text {
  font-size: 22rpx;
  color: #fff;
}

.points-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 28rpx;
}

/* 统计数据 */
.stats-row {
  display: flex;
  align-items: center;
  width: 100%;
  padding: 24rpx 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.2);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* 关注按钮 */
.follow-action {
  margin-top: 28rpx;
}

.follow-action-btn {
  padding: 16rpx 64rpx;
  border-radius: 40rpx;
  background: #fff;
}

.follow-action-btn text {
  font-size: 28rpx;
  color: #007aff;
  font-weight: 600;
}

.follow-action-btn.following {
  background: rgba(255, 255, 255, 0.25);
}

.follow-action-btn.following text {
  color: #fff;
}

/* ── 作品列表 ── */

.section-title {
  padding: 28rpx 32rpx 12rpx;
}

.section-title text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.post-list {
  flex: 1;
  padding: 8rpx 24rpx;
  box-sizing: border-box;
}

.post-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: #e0e0e0;
}

.post-user {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.time {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.post-body {
  margin-bottom: 20rpx;
}

.theme {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.content {
  display: block;
  font-size: 28rpx;
  color: #444;
  line-height: 1.6;
  word-break: break-all;
}

.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
}

.post-image {
  width: 210rpx;
  height: 210rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.post-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.bar-item {
  display: flex;
  align-items: center;
  margin-right: 48rpx;
  padding: 8rpx 0;
}

.bar-item .icon {
  font-size: 28rpx;
  margin-right: 6rpx;
}

.bar-item .count {
  font-size: 24rpx;
  color: #888;
}

.bar-item .label {
  font-size: 24rpx;
  color: #888;
}

/* ── 空状态 ── */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 120rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.list-footer {
  height: 60rpx;
}
