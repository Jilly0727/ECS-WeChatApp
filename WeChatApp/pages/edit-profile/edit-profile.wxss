.container {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  position: relative;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: #eee;
}

.change-tip {
  font-size: 24rpx;
  color: #007aff;
  margin-top: 10rpx;
  text-align: center;
}

.field {
  width: 100%;
}

.input {
  width: 100%;
  font-size: 30rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.footer {
  margin-top: 60rpx;
  padding: 0 20rpx;
}

.btn-save {
  width: 100%;
  height: 88rpx;
  background: #007aff;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}

.btn-save[disabled] {
  background: #ccc;
}
