/* pages/profile/profile.wxss */

/* ========== 页面背景 ========== */
page {
  background: #f5f5f5;
}
.container {
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ========== 顶部蓝色区域 ========== */
.header-bg {
  background: linear-gradient(180deg, #3b7fff, #5b8ff9);
  padding: 40rpx 30rpx 50rpx;
}

.user-row {
  display: flex;
  align-items: flex-start;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: 1;
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
}

.avatar-btn::after {
  border: none;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3);
  background: #fff;
}

.user-main {
  margin-left: 24rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.edit-icon {
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
  margin-left: 12rpx;
}

.level-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.level-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
}

.points-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.points-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}

.points-detail-link {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}

/* ========== 数据统计卡片 ========== */
.stats-row {
  display: flex;
  margin: -20rpx 24rpx 0;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  position: relative;
  z-index: 1;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  background: #eee;
  align-self: stretch;
  margin: 10rpx 0;
}

/* ========== 菜单区域 ========== */
.menu-group {
  margin: 20rpx 24rpx;
}

.menu-section {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.menu-item-main {
  margin-bottom: 0;
  border-radius: 16rpx 16rpx 0 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  width: 44rpx;
  text-align: center;
}

.menu-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 子菜单项 */
.menu-sub-item {
  padding: 24rpx 24rpx 24rpx 84rpx;
  background: #fff;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-sub-item:last-child {
  border-radius: 0 0 16rpx 16rpx;
  border-bottom: none;
}

.sub-text {
  font-size: 26rpx;
  color: #666;
}
