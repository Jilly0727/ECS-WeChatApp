<view class="container">
  <view class="header">
    <text class="title">我的预约</text>
    <text class="subtitle">共 {{myBookings.length}} 条记录</text>
  </view>

  <view class="list" wx:if="{{!loading}}">
    <block wx:for="{{myBookings}}" wx:key="_id">
      <view class="card">
        <view class="card-top">
          <text class="course-name">{{item.courseName}}</text>
          <text class="status {{item.status === 'cancelled' ? 'cancelled' : item.status === 'checked_in' ? 'completed' : 'active'}}">
            {{item.status === 'booked' ? '已预约' : item.status === 'checked_in' ? '已签到' : '已取消'}}
          </text>
        </view>

        <view class="card-info">
          <view class="info-item">
            <text class="label">讲师：</text>
            <text>{{item.teacher}}</text>
          </view>
          <view class="info-item">
            <text class="label">时间：</text>
            <text>{{item.time}}</text>
          </view>
        </view>

        <view class="points-badge" wx:if="{{item.status === 'checked_in' && item.pointsEarned > 0}}">
          <text class="points-text">+{{item.pointsEarned}} 积分</text>
        </view>

        <view class="card-footer" wx:if="{{item.status === 'booked'}}">
          <button class="btn-checkin" size="mini" bindtap="doCheckin" data-id="{{item._id}}">签到</button>
          <button class="btn-cancel" size="mini" bindtap="cancelBooking" data-id="{{item._id}}">取消预约</button>
        </view>
      </view>
    </block>

    <view wx:if="{{myBookings.length === 0}}" class="empty">
      <text>暂无预约记录</text>
    </view>
  </view>
</view>
