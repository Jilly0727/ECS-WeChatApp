/* pages/index/index.wxss */
.container {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.header {
  margin-bottom: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  margin-top: 10rpx;
  display: block;
}

.quick-actions {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.action-card {
  width: 48%;
  height: 150rpx;
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
}

.create-btn {
  background: linear-gradient(135deg, #e0f2ff, #ffffff);
}

.record-btn {
  background: linear-gradient(135deg, #fff0f0, #ffffff);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  display: block;
}

.course-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.course-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background-color: #eee;
  margin-right: 20rpx;
}

.course-info {
  flex: 1;
}

.course-name {
  font-size: 30rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 10rpx;
}

.course-teacher {
  font-size: 24rpx;
  color: #999;
}